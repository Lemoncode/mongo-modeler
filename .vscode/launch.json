{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Mongo Modeler Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-extension"
      ],
      "outFiles": ["${workspaceFolder}/packages/vscode-extension/dist/**/*.mjs"]
    }
  ]
}
