{
  "name": "@lemoncode/mongo-modeler-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "start": "node --run dev",
    "dev": "tsx tooling/dev-cli/dev.ts",
    "build": "turbo build",
    "test": "turbo test",
    "test:watch": "tsx tooling/dev-cli/test-watch.ts",
    "test:coverage": "turbo test:coverage",
    "check-types": "turbo check-types",
    "e2e": "turbo e2e",
    "ci:e2e": "turbo ci:e2e",
    "install:test-browsers": "npx playwright install --with-deps",
    "lint": "oxlint . --quiet",
    "lint:fix": "oxlint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "publish:vscode": "tsx tooling/publish/publish-vscode.ts",
    "package:vscode": "node --run build && cd packages/vscode-extension && npx vsce package --no-dependencies --out ./dist",
    "prepare": "husky || \"No need to install husky\""
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "24.12.4",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxlint": "1.66.0",
    "prettier": "3.8.3",
    "tsx": "4.22.3",
    "turbo": "2.9.14",
    "typescript": "6.0.3"
  }
}